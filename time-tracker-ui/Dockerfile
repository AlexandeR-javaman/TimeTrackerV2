FROM node:18 AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ARG REACT_APP_API_GATEWAY_BASE_URL
ARG REACT_APP_KEYCLOAK_URL
ARG REACT_APP_KEYCLOAK_REALM
ARG REACT_APP_KEYCLOAK_CLIENT_ID
ARG REACT_APP_LOG_ENTRY_PATH
ARG REACT_APP_EMPLOYEE_PATH
ENV REACT_APP_API_GATEWAY_BASE_URL=$REACT_APP_API_GATEWAY_BASE_URL
ENV REACT_APP_KEYCLOAK_URL=$REACT_APP_KEYCLOAK_URL
ENV REACT_APP_KEYCLOAK_REALM=$REACT_APP_KEYCLOAK_REALM
ENV REACT_APP_KEYCLOAK_CLIENT_ID=$REACT_APP_KEYCLOAK_CLIENT_ID
ENV REACT_APP_LOG_ENTRY_PATH=$REACT_APP_LOG_ENTRY_PATH
ENV REACT_APP_EMPLOYEE_PATH=$REACT_APP_EMPLOYEE_PATH
RUN npm run build
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]